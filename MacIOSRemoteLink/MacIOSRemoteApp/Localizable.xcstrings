      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Error" } },
        "ja": { "stringUnit": { "state": "translated", "value": "エラー" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Lỗi" } }
      }
    },
    "try_again_button": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Try Again" } },
        "ja": { "stringUnit": { "state": "translated", "value": "再試行" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Thử lại" } }
      }
    },
    "connect_title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Connect" } },
        "ja": { "stringUnit": { "state": "translated", "value": "接続" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Kết nối" } }
      }
    },
    "enter_pin_hint": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Enter the PIN or password shown on your Mac" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Macに表示されているPINまたはパスワードを入力してください" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Nhập mã PIN hoặc mật khẩu hiển thị trên Mac của bạn" } }
      }
    },
    "pin_or_password_placeholder": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "PIN or Password" } },
        "ja": { "stringUnit": { "state": "translated", "value": "PINまたはパスワード" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Mã PIN hoặc Mật khẩu" } }
      }
    },
    "connect_button": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Connect" } },
        "ja": { "stringUnit": { "state": "translated", "value": "接続する" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Kết nối" } }
      }
    },
    "remote_ip_header": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Remote IP" } },
        "ja": { "stringUnit": { "state": "translated", "value": "リモートIPアドレス" } },
        "vi": { "stringUnit": { "state": "translated", "value": "IP từ xa" } }
      }
    },
    "remote_ip_description %llu": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Enter your Mac's IP address or hostname.\nPort %llu must be forwarded on your router." } },
        "ja": { "stringUnit": { "state": "translated", "value": "MacのIPアドレスまたはホスト名を入力してください。\nルーターでポート%lluを転送する必要があります。" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Nhập địa chỉ IP hoặc tên máy chủ Mac của bạn.\nCần chuyển tiếp cổng %llu trên router." } }
      }
    },
    "hostname_placeholder": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Hostname or IP address" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ホスト名またはIPアドレス" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Tên máy chủ hoặc địa chỉ IP" } }
      }
    },
    "port_placeholder": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Port" } },
        "ja": { "stringUnit": { "state": "translated", "value": "ポート" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Cổng" } }
      }
    },
    "searching_for_mac": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Searching for Mac..." } },
        "ja": { "stringUnit": { "state": "translated", "value": "Macを検索中..." } },
        "vi": { "stringUnit": { "state": "translated", "value": "Đang tìm kiếm Mac..." } }
      }
    },
    "searching_hint": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Make sure MyRemote Server is running on your Mac\nand both devices are on the same WiFi network." } },
        "ja": { "stringUnit": { "state": "translated", "value": "MacでMyRemoteサーバーが起動していることと、\n両方のデバイスが同じWiFiネットワークに接続していることを確認してください。" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Đảm bảo MyRemote Server đang chạy trên Mac của bạn\nvà cả hai thiết bị đều kết nối cùng mạng WiFi." } }
      }
    },
    "server_available_label": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Available" } },
        "ja": { "stringUnit": { "state": "translated", "value": "利用可能" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Sẵn sàng" } }
      }
    }
  },
  "version": "1.1"
}
