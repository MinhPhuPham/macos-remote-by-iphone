        "en": { "stringUnit": { "state": "translated", "value": "Connection Mode" } },
        "ja": { "stringUnit": { "state": "translated", "value": "接続方法" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Chế độ kết nối" } }
      }
    },
    "default_server_name": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Mac" } },
        "ja": { "stringUnit": { "state": "translated", "value": "Mac" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Mac" } }
      }
    },
    "waiting_for_approval %@": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Waiting for %@ to approve..." } },
        "ja": { "stringUnit": { "state": "translated", "value": "%@の承認を待っています..." } },
        "vi": { "stringUnit": { "state": "translated", "value": "Đang chờ %@ chấp thuận..." } }
      }
    },
    "check_mac_approval": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Check your Mac for the approval dialog." } },
        "ja": { "stringUnit": { "state": "translated", "value": "Macの承認ダイアログを確認してください。" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Kiểm tra hộp thoại chấp thuận trên Mac của bạn." } }
      }
    },
    "connecting_title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Connecting" } },
        "ja": { "stringUnit": { "state": "translated", "value": "接続中" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Đang kết nối" } }
      }
    },
    "reconnecting_message": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reconnecting..." } },
        "ja": { "stringUnit": { "state": "translated", "value": "再接続中..." } },
        "vi": { "stringUnit": { "state": "translated", "value": "Đang kết nối lại..." } }
      }
    },
    "reconnect_attempt %lld %lld": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Attempt %1$lld of %2$lld" } },
        "ja": { "stringUnit": { "state": "translated", "value": "%2$lld回中%1$lld回目" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Lần thử %1$lld / %2$lld" } }
      }
    },
    "cancel_button": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Cancel" } },
        "ja": { "stringUnit": { "state": "translated", "value": "キャンセル" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Hủy" } }
      }
    },
    "reconnecting_title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reconnecting" } },
        "ja": { "stringUnit": { "state": "translated", "value": "再接続中" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Đang kết nối lại" } }
      }
    },
