{
  "sourceLanguage": "en",
  "strings": {
    "app_title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "MyRemote" } },
        "ja": { "stringUnit": { "state": "translated", "value": "MyRemote" } },
        "vi": { "stringUnit": { "state": "translated", "value": "MyRemote" } }
      }
    },
    "same_wifi_tab": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Same WiFi" } },
        "ja": { "stringUnit": { "state": "translated", "value": "同じWiFi" } },
        "vi": { "stringUnit": { "state": "translated", "value": "Cùng WiFi" } }
      }
    },
    "remote_ip_tab": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Remote IP" } },
        "ja": { "stringUnit": { "state": "translated", "value": "リモートIP" } },
        "vi": { "stringUnit": { "state": "translated", "value": "IP từ xa" } }
      }
