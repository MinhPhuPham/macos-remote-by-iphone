    "grant_permissions_hint" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Grant permissions in System Settings → Privacy & Security" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "システム設定 → プライバシーとセキュリティで権限を付与してください" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Cấp quyền trong Cài đặt hệ thống → Quyền riêng tư & Bảo mật" } }
      }
    },
    "guide_step_1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open your router admin page (usually 192.168.1.1)" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ルーターの管理ページを開く（通常は192.168.1.1）" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Mở trang quản trị router (thường là 192.168.1.1)" } }
      }
    },
    "guide_step_2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Find 'Port Forwarding' or 'Virtual Server' or 'NAT'" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "「ポート転送」「仮想サーバー」または「NAT」を探す" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Tìm mục 'Chuyển tiếp cổng' hoặc 'Máy chủ ảo' hoặc 'NAT'" } }
      }
    },
    "guide_step_3 %@" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add rule: External port 5910 → %@:5910 TCP" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ルールを追加：外部ポート5910 → %@:5910 TCP" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Thêm quy tắc: Cổng ngoài 5910 → %@:5910 TCP" } }
      }
    },
    "guide_step_4 %@" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "On iPhone, enter your Public IP: %@" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "iPhoneでパブリックIPを入力：%@" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Trên iPhone, nhập IP công cộng của bạn: %@" } }
      }
    },
    "guide_step_5" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make sure macOS Firewall allows incoming connections" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "macOSファイアウォールが受信接続を許可していることを確認してください" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Đảm bảo Tường lửa macOS cho phép kết nối đến" } }
      }
    },
    "guide_vpn_note" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If you don't have router admin access, you'll need a VPN (e.g. Tailscale) or a relay server to connect remotely." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ルーターの管理者アクセスがない場合は、VPN（例：Tailscale）またはリレーサーバーが必要です。" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Nếu không có quyền quản trị router, bạn cần VPN (ví dụ: Tailscale) hoặc máy chủ relay để kết nối từ xa." } }
      }
    },
